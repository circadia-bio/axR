#!/bin/sh
# Generates src/Makevars from src/Makevars.in based on the build platform.
#
# The OS-conditional logic (which device-finder object to compile, which
# system libraries to link) lives here in a plain POSIX shell script
# rather than as ifeq/$(shell)/:= in src/Makevars itself, so the generated
# Makevars stays free of GNU Make extensions -- see 'Writing portable
# packages' in the R Extensions manual.
#
# This mirrors upstream libomapi's own src/Makefile conditionals
# (Darwin -> omapi-devicefinder-mac.c + Cocoa/IOKit/DiskArbitration;
# Linux -> omapi-devicefinder-linux.c + udev), just relocated from make
# syntax to shell syntax.

UNAME_S=`uname -s`

# axR patch: detect a WebAssembly/Emscripten cross-compile (e.g.
# r-universe's webR/wasm build target). `uname -s` alone can't tell us
# this -- it reports the *host* OS (still "Linux" even when
# cross-compiling to wasm32-unknown-emscripten via emconfigure), so check
# the --host argument this script is actually invoked with instead
# (confirmed via a real r-universe wasm build log:
# "./configure.orig --build=x86_64-pc-linux-gnu --host=wasm32-unknown-emscripten").
IS_WASM=no
for arg in "$@"; do
  case "$arg" in
    --host=*emscripten*|--host=wasm*) IS_WASM=yes ;;
  esac
done
case "$CC" in
  *emcc*) IS_WASM=yes ;;
esac

if [ "$IS_WASM" = "yes" ]; then
  # No udev/IOKit/SetupAPI equivalent exists inside a WASM sandbox, and
  # raw USB/serial access isn't available to a WASM module regardless --
  # this isn't a missing library to chase, device discovery genuinely
  # doesn't apply to this target. Build with a no-op stub instead (see
  # omapi-devicefinder-wasm.c) so the package still compiles for
  # webR/browser use -- axivity_read_cwa()/axivity_copy_data() and
  # everything else that doesn't need a live device still works there;
  # axivity_discover() just always reports zero devices.
  OMAPI_FINDER_OBJ="omapi/omapi-devicefinder-wasm.o"
  OMAPI_LIBS="-lpthread"
elif [ "$UNAME_S" = "Darwin" ]; then
  OMAPI_FINDER_OBJ="omapi/omapi-devicefinder-mac.o"
  OMAPI_LIBS="-lpthread -framework Cocoa -framework IOKit -framework DiskArbitration"
else
  # Linux (including WSL): requires libudev-dev (or equivalent) --
  # see DESCRIPTION's SystemRequirements.
  OMAPI_FINDER_OBJ="omapi/omapi-devicefinder-linux.o"
  OMAPI_LIBS="-lpthread -ludev"
fi

sed -e "s|@OMAPI_FINDER_OBJ@|$OMAPI_FINDER_OBJ|" \
    -e "s|@OMAPI_LIBS@|$OMAPI_LIBS|" \
    src/Makevars.in > src/Makevars

exit 0
