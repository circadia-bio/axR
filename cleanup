#!/bin/sh
# Removes files generated by ./configure and by compilation, so the
# source tree can be checked or built again from a clean state.
# See 'Configure and cleanup' in the 'Writing R Extensions' manual.

rm -f src/Makevars
rm -f src/*.o src/*.so src/*.dll
rm -f src/omapi/*.o src/omapi/*.so src/omapi/*.dll

exit 0
